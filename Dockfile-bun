FROM oven/bun:alpine

RUN bun install autocannon -g

# 安装 curl 用于 URL 测试
RUN apk add --no-cache curl

# 复制入口脚本
COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# 设置默认环境变量
ENV th=2
#ENV time=2147483647sec
ENV url_custom=""
ENV ui=--no-progress
ENV tool=autocannon

# 使用新的入口脚本，支持多个备用 URL
ENTRYPOINT ["/entrypoint.sh"]
